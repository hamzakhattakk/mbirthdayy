<script>
// ── Apply config ──────────────────────────────────────────────
document.querySelectorAll('#name-display,#name-display-final').forEach(e=>e.textContent=PERSON_NAME);
document.getElementById('main-message').textContent=MAIN_MESSAGE;
document.getElementById('memory-caption').textContent=MEMORY_CAPTION;
document.getElementById('song-title').textContent=SONG_TITLE;
document.getElementById('song-artist').textContent=SONG_ARTIST;

const tl=document.getElementById('trait-list');
TRAITS.forEach(t=>{const d=document.createElement('div');d.className='trait';d.textContent=t;tl.appendChild(d);});

const wl=document.getElementById('wish-list');
WISHES.forEach(w=>{const li=document.createElement('li');li.innerHTML=`<span class="icon">${w.icon}</span>${w.text}`;wl.appendChild(li);});

// ── Slide engine ──────────────────────────────────────────────
const slides=Array.from(document.querySelectorAll('.slide'));
const total=slides.length;
let current=0, busy=false;
let gateUnlocked=false; // slide 1 gate

// ── PASSWORD GATE ─────────────────────────────────────────────
function checkAnswer(){
  const inp=document.getElementById('gate-input');
  const val=inp.value.trim().toLowerCase();
  if(val==='hamzito'){
    // success
    document.getElementById('gate-form').style.display='none';
    const success=document.getElementById('gate-success');
    success.style.display='flex';
    gateUnlocked=true;
  } else {
    // wrong — shake + red
    inp.classList.remove('wrong');
    void inp.offsetWidth; // reflow to restart animation
    inp.classList.add('wrong');
    inp.value='';
    inp.placeholder='try again…';
    setTimeout(()=>{ inp.classList.remove('wrong'); inp.placeholder='type your answer…'; },1200);
  }
}

function setPositions(anim){
  slides.forEach((s,i)=>{
    s.style.transition=anim?`transform var(--dur) cubic-bezier(0.4,0,0.1,1)`:'none';
    s.style.transform=`translateY(${(i-current)*100}vh)`;
  });
}
// snap-back uses a quicker spring
function snapBack(){
  slides.forEach((s,i)=>{
    s.style.transition=`transform 0.4s cubic-bezier(0.25,1,0.4,1)`;
    s.style.transform=`translateY(${(i-current)*100}vh)`;
  });
}
setPositions(false);
slides[0].classList.add('in-view');

// dots
const dotsEl=document.getElementById('dots');
slides.forEach((_,i)=>{
  const d=document.createElement('div');
  d.className='dot'+(i===0?' active':'');
  d.onclick=()=>goTo(i);
  dotsEl.appendChild(d);
});

function goTo(idx){
  if(idx===current||idx<0||idx>=total||busy) return;
  // gate: can't leave slide 0 until unlocked
  if(current===0&&idx>0&&!gateUnlocked) return;
  busy=true;
  slides[current].classList.remove('in-view');
  slides[current].querySelectorAll('.anim-child').forEach(el=>{el.style.animation='none';void el.offsetWidth;el.style.animation='';});
  current=idx;
  setPositions(true);
  setTimeout(()=>{
    slides[current].classList.add('in-view');
    slides[current].querySelectorAll('.anim-child').forEach(el=>{el.style.animation='none';void el.offsetWidth;el.style.animation='';});
    busy=false;
  },30);
  if(current===total-1){ setTimeout(launchConfetti,700); renderPngs(); }
  updateAudio(current);
  updateUI();
}
function changeSlide(dir){if(!busy)goTo(current+dir);}

function updateUI(){
  document.querySelectorAll('.dot').forEach((d,i)=>d.classList.toggle('active',i===current));
  document.getElementById('btn-prev').style.opacity=current===0?'0.2':'1';
  document.getElementById('btn-next').style.opacity=current===total-1?'0.2':'1';
  document.getElementById('swipe-hint').style.opacity=current===total-1?'0':'0.32';
}
updateUI();

// keyboard
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowDown'||e.key==='ArrowRight') changeSlide(1);
  if(e.key==='ArrowUp'  ||e.key==='ArrowLeft')  changeSlide(-1);
});

// wheel
let wc=false;
document.addEventListener('wheel',e=>{
  if(wc) return; wc=true;
  if(e.deltaY>30) changeSlide(1);
  else if(e.deltaY<-30) changeSlide(-1);
  setTimeout(()=>{wc=false;},900);
},{passive:true});

// touch — follows finger in real time, snaps on release
let ty0=0, dragDelta=0, dragging=false;

function applyDrag(delta){
  const vh=window.innerHeight;
  const maxDrag=vh*0.4;
  let d=delta;
  // block upward drag on slide 0 if gate not unlocked
  if(current===0&&d<0&&!gateUnlocked) d=0;
  if((current===0&&d>0)||(current===total-1&&d<0)){
    d=d*(0.2);
  }
  d=Math.max(-maxDrag,Math.min(maxDrag,d));
  slides.forEach((s,i)=>{
    s.style.transition='none';
    s.style.transform=`translateY(calc(${(i-current)*100}vh + ${d}px))`;
  });
}

document.addEventListener('touchstart',e=>{
  if(busy) return;
  ty0=e.touches[0].clientY;
  dragDelta=0;
  dragging=true;
},{passive:true});

document.addEventListener('touchmove',e=>{
  if(!dragging) return;
  dragDelta=e.touches[0].clientY - ty0;
  applyDrag(dragDelta);
},{passive:true});

document.addEventListener('touchend',()=>{
  if(!dragging) return;
  dragging=false;
  if(dragDelta<-10) goTo(current+1);
  else if(dragDelta>10) goTo(current-1);
  else snapBack();
},{passive:true});

// ── COUNTDOWN ────────────────────────────────────────────────
function startCountdown(){
  function tick(){
    const diff=BIRTHDAY_DATE-new Date();
    if(diff<=0){
      ['cd-days','cd-hours','cd-mins','cd-secs'].forEach(id=>document.getElementById(id).textContent='00');
      return;
    }
    const days=Math.floor(diff/864e5);
    const hours=Math.floor((diff%864e5)/36e5);
    const mins=Math.floor((diff%36e5)/6e4);
    const secs=Math.floor((diff%6e4)/1e3);
    document.getElementById('cd-days').textContent=String(days).padStart(2,'0');
    document.getElementById('cd-hours').textContent=String(hours).padStart(2,'0');
    document.getElementById('cd-mins').textContent=String(mins).padStart(2,'0');
    document.getElementById('cd-secs').textContent=String(secs).padStart(2,'0');
  }
  tick(); setInterval(tick,1000);
}
startCountdown();

// ── AUDIO ────────────────────────────────────────────────────
let audio=null, audioPlaying=false, currentSrc='', fadeTimer=null;

function fadeIn(audioEl, duration=500){
  audioEl.volume=0;
  const steps=30;
  const interval=duration/steps;
  let step=0;
  clearInterval(fadeTimer);
  fadeTimer=setInterval(()=>{
    step++;
    audioEl.volume=Math.min(1, step/steps);
    if(step>=steps) clearInterval(fadeTimer);
  }, interval);
}

function fadeOutAndStop(audioEl, duration=300, cb){
  const startVol=audioEl.volume;
  const steps=20;
  const interval=duration/steps;
  let step=0;
  clearInterval(fadeTimer);
  fadeTimer=setInterval(()=>{
    step++;
    audioEl.volume=Math.max(0, startVol*(1-step/steps));
    if(step>=steps){
      clearInterval(fadeTimer);
      audioEl.pause();
      if(cb) cb();
    }
  }, interval);
}

function updateDiscUI(song, playing){
  const disc=document.getElementById('disc');
  const tog=document.getElementById('disc-toggle');
  disc.classList.toggle('spinning', playing);
  if(tog) tog.textContent=playing?'⏸':'▶';
  if(song){
    document.getElementById('disc-title').textContent=song.title;
    document.getElementById('disc-artist').textContent=song.artist;
  }
  // hide info/toggle on song slide (idx 5), show big disc only
  document.getElementById('disc-player').classList.toggle('on-song-slide', current===5);
}

function updateAudio(idx){
  const song=SONGS[idx];
  const newSrc=song&&song.src?song.src:'';

  // same track — keep looping
  if(newSrc&&newSrc===currentSrc&&audio){
    updateDiscUI(song, audioPlaying);
    return;
  }

  const oldAudio=audio;
  audio=null; audioPlaying=false; currentSrc=newSrc;

  const startNew=()=>{
    if(!newSrc){
      updateDiscUI(song, false);
      return;
    }
    const a=new Audio(newSrc);
    a.loop=true; a.volume=0;
    audio=a;
    a.play()
      .then(()=>{ audioPlaying=true; fadeIn(a,500); updateDiscUI(song,true); })
      .catch(()=>{ updateDiscUI(song,false); });
  };

  if(oldAudio&&!oldAudio.paused){
    fadeOutAndStop(oldAudio,300,startNew);
  } else {
    if(oldAudio) oldAudio.pause();
    startNew();
  }
}

function toggleAudio(){
  if(!audio) return;
  if(audioPlaying){
    fadeOutAndStop(audio,300,()=>{
      audioPlaying=false;
      updateDiscUI(SONGS[current],false);
    });
  } else {
    audio.play().then(()=>{
      audioPlaying=true;
      fadeIn(audio,500);
      updateDiscUI(SONGS[current],true);
    });
  }
}

