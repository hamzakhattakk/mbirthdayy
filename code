// ║  Example: "balloon.png", "star.png", "flower.png"            ║
// ╚══════════════════════════════════════════════════════════════╝
const PNG_FILES = [
  // "image1.png",
  // "image2.png",
  // "image3.png",
  // "image4.png",
];

const pngLayer=document.getElementById('png-layer');

const SLOT_POSITIONS=[
  {top:'6%', left:'4%'},  {top:'4%',  right:'5%'},
  {top:'28%',left:'1%'},  {top:'22%', right:'2%'},
  {bottom:'6%',left:'5%'},{bottom:'5%',right:'4%'},
  {top:'50%', left:'0%'}, {top:'55%', right:'1%'},
  {top:'14%', left:'36%'},{bottom:'18%',left:'34%'},
  {top:'38%', left:'15%'},{top:'40%', right:'14%'},
];
const ROTS=['-14deg','-7deg','-3deg','0deg','4deg','8deg','13deg','-10deg','6deg','-5deg','11deg','-2deg'];

function renderPngs(){
  pngLayer.innerHTML='';
  PNG_FILES.forEach((src,i)=>{
    const img=document.createElement('img');
    img.src=src; img.className='pop-png';
    const pos=SLOT_POSITIONS[i%SLOT_POSITIONS.length];
    const rot=ROTS[i%ROTS.length];
    Object.assign(img.style, pos);
    img.style.setProperty('--rot',rot);
    img.style.setProperty('--pop-dur','0.45s');
    img.style.setProperty('--pop-delay',(i*0.08)+'s');
    pngLayer.appendChild(img);
  });
}

// ── CONFETTI ──────────────────────────────────────────────────
const canvas=document.getElementById('confetti-canvas');
const ctx=canvas.getContext('2d');
let pieces=[];

function launchConfetti(){
  canvas.width=window.innerWidth; canvas.height=window.innerHeight;
  const colors=['#c84878','#e8789a','#f0a8c0','#fdd8e8','#8B2252','#f5c0d8','#ffffff'];
  for(let i=0;i<220;i++){
    pieces.push({
      x:Math.random()*canvas.width, y:Math.random()*-canvas.height*1.2,
      w:Math.random()*10+4, h:Math.random()*6+3,
      color:colors[Math.floor(Math.random()*colors.length)],
      r:Math.random()*Math.PI*2, dr:(Math.random()-0.5)*0.14,
      dy:Math.random()*3+1.5, dx:(Math.random()-0.5)*1.5,
    });
  }
  requestAnimationFrame(drawConfetti);
}

function drawConfetti(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  pieces=pieces.filter(p=>p.y<canvas.height+20);
  pieces.forEach(p=>{
    ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.r);
    ctx.fillStyle=p.color;ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
    ctx.restore();
    p.y+=p.dy;p.x+=p.dx;p.r+=p.dr;
  });
  if(pieces.length>0) requestAnimationFrame(drawConfetti);
}
</script>
