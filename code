<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --amber: #c84878;
    --amber-light: #c84878;
    --rust: #8B2252;
    --cream: #3a1a2a;
    --rose: #e8789a;
    --rose-light: #a03060;
    --dur: 0.9s;
  }

  html, body {
    height: 100%; width: 100%;
    overflow: hidden;
    background: #FFF0F5;
    font-family: 'DM Sans', sans-serif;
    color: #3a1a2a;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  body::after {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 2000; opacity: 0.35;
  }

  #reel { position: fixed; inset: 0; overflow: hidden; }

  .slide {
    position: absolute; left: 0; right: 0; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: clamp(1.2rem, 5vw, 2.5rem);
    overflow: hidden;
    will-change: transform;
    transition: transform var(--dur) cubic-bezier(0.4,0,0.1,1);
  }

  .slide-1  { background: linear-gradient(150deg,#FFF0F3 0%,#FFE4EC 40%,#FDD8E8 100%); color: #3a1a2a; }
  .slide-2  { background: #FFF0F5; color: #3a1a2a; }
  .slide-3  { background: #FDE8F0; color: #3a1a2a; }
  .slide-4  { background: #FCE0EA; color: #3a1a2a; }
  .slide-5  { background: #FBD8E5; color: #3a1a2a; }
  .slide-6  { background: #FAD0E0; color: #3a1a2a; }
  .slide-7  { background: #F9C8DA; color: #3a1a2a; }
  .slide-final { background: #ffffff; color: #1a1a1a; }

  .deco {
    position: absolute; border-radius: 50%;
    pointer-events: none; z-index: 0;
    filter: blur(60px); opacity: 0.22;
  }

  .overline {
    font-size: clamp(10px,2.5vw,13px); font-weight: 500;
    letter-spacing: 0.25em; text-transform: uppercase;
    opacity: 0.55; margin-bottom: 0.8rem;
  }
  .headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.6rem,10vw,6.5rem);
    font-weight: 700; line-height: 1.0;
    color: var(--amber-light); text-align: center;
  }
  .headline em { font-style: italic; color: var(--rose-light); }
  .subhead {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem,3.5vw,1.8rem);
    font-style: italic; color: var(--rose-light);
    text-align: center; margin-top: 0.6rem;
  }
  .body-text {
    font-size: clamp(0.9rem,2.3vw,1.1rem);
    line-height: 1.75; opacity: 0.82;
    text-align: center; max-width: 500px;
  }
  .stat-label {
    font-size: clamp(0.75rem,1.8vw,0.95rem);
    letter-spacing: 0.15em; text-transform: uppercase;
    opacity: 0.5; margin-top: 0.4rem; text-align: center;
  }
  .name-pill {
    display: inline-block;
    background: rgba(232,160,69,0.18); border: 1px solid rgba(232,160,69,0.4);
    border-radius: 100px; padding: 0.3rem 1.1rem;
    font-size: clamp(0.75rem,2vw,0.9rem); color: var(--amber-light);
    letter-spacing: 0.1em; margin-bottom: 1.2rem;
  }
  .content-stack {
    position: relative; z-index: 2;
    display: flex; flex-direction: column;
    align-items: center; gap: 0.85rem;
    max-width: 680px; width: 100%;
  }

  /* side dots */
  #dots {
    position: fixed; right: 1rem; top: 50%;
    transform: translateY(-50%);
    display: flex; flex-direction: column; gap: 7px; z-index: 1999;
  }
  .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(180,60,100,0.25);
    transition: all 0.3s; cursor: pointer;
  }
  .dot.active { height: 22px; border-radius: 3px; background: #c84878; }

  /* desktop arrows */
  .nav-btn {
    position: fixed; left: 50%; transform: translateX(-50%);
    background: rgba(200,72,120,0.08); border: 1px solid rgba(200,72,120,0.25);
    color: rgba(180,60,100,0.6); width: 42px; height: 42px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 1999; transition: all 0.2s;
    backdrop-filter: blur(8px); font-size: 17px;
  }
  .nav-btn:hover { background: rgba(200,72,120,0.15); color: #c84878; }
  #btn-prev { top: 1rem; }
  #btn-next { bottom: 1rem; }
  @media (max-width:600px){ .nav-btn { display:none; } #dots { display:none; } }

  #swipe-hint {
    position: fixed; bottom: 1.4rem; left: 50%; transform: translateX(-50%);
    font-size: 11px; opacity: 0.32; letter-spacing: 0.12em; color: #8B2252;
    z-index: 1999; pointer-events: none; text-transform: uppercase;
    display: none;
  }
  @media (max-width:600px){ #swipe-hint { display: block; } }

  /* ── DISC PLAYER (top-left, all slides except song slide) ── */
  #disc-player {
    position: fixed; top: 1.1rem; left: 1.1rem;
    display: flex; align-items: center; gap: 10px;
    z-index: 1999; pointer-events: all;
  }
  #disc-wrap {
    position: relative; width: 48px; height: 48px; cursor: pointer; flex-shrink: 0;
  }
  #disc {
    width: 48px; height: 48px; border-radius: 50%;
    background: conic-gradient(
      #c84878 0deg, #e8789a 60deg, #f0a8c0 120deg,
      #fdd8e8 180deg, #c84878 240deg, #e8789a 300deg, #c84878 360deg
    );
    box-shadow: 0 2px 12px rgba(200,72,120,0.3);
    animation: disc-spin 3s linear infinite;
    animation-play-state: paused;
  }
  #disc.spinning { animation-play-state: running; }
  #disc::after {
    content: '';
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 14px; height: 14px; border-radius: 50%;
    background: white;
    box-shadow: 0 0 0 2px rgba(200,72,120,0.25);
  }
  /* album art on disc when set */
  #disc-img {
    position: absolute; inset: 0; border-radius: 50%;
    object-fit: cover; width: 100%; height: 100%;
    display: none;
  }
  #disc-img.visible { display: block; }
  #disc-img::after {
    content: ''; position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 14px; height: 14px; border-radius: 50%;
    background: white;
  }
  /* centre hole overlay on top of album art */
  #disc-hole {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 14px; height: 14px; border-radius: 50%;
    background: white; z-index: 2;
    box-shadow: 0 0 0 2px rgba(200,72,120,0.2);
    pointer-events: none;
  }
  @keyframes disc-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  #disc-info {
    display: flex; flex-direction: column; gap: 1px;
    max-width: 140px; overflow: hidden;
  }
  #disc-title {
    font-size: 11px; font-weight: 500; color: #8B2252;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  #disc-artist {
    font-size: 10px; color: #c84878; opacity: 0.7;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  #disc-toggle {
    background: none; border: none; color: #c84878;
    font-size: 13px; cursor: pointer; padding: 0; line-height: 1;
    flex-shrink: 0;
  }

  /* hide disc on song slide (index 5) — handled by JS class */
  #disc-player.on-song-slide #disc-info,
  #disc-player.on-song-slide #disc-toggle { display: none; }

  /* ── MEMORY CAROUSEL ── */
  .memory-carousel-wrap {
    width: 100%; max-width: 600px;
    overflow: hidden; position: relative;
  }
  .memory-carousel {
    display: flex; gap: 14px;
    overflow-x: auto; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; padding: 0.5rem 1rem;
    cursor: grab;
  }
  .memory-carousel::-webkit-scrollbar { display: none; }
  .memory-carousel:active { cursor: grabbing; }
  .memory-card-item {
    scroll-snap-align: center; flex-shrink: 0;
    width: clamp(150px, 55vw, 220px);
    aspect-ratio: 3/4;
    border-radius: 16px; border: 2px dashed rgba(200,72,120,0.3);
    background: rgba(255,255,255,0.5);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.4rem; font-size: 0.75rem; color: #c84878;
    position: relative; overflow: hidden;
    transition: transform 0.2s;
  }
  .memory-card-item:hover { transform: scale(1.02); }
  .memory-card-item input[type=file] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer;
  }
  .memory-card-item img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; border-radius: 14px;
  }
  .memory-card-item .card-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; font-weight: 700; color: rgba(200,72,120,0.3);
  }
  .memory-dots {
    display: flex; gap: 6px; justify-content: center; margin-top: 0.4rem;
  }
  .memory-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(200,72,120,0.25); transition: all 0.3s;
  }
  .memory-dot.active { width: 16px; border-radius: 3px; background: #c84878; }

  /* child animations */
  .anim-child { opacity: 0; }
  .slide.in-view .anim-child { animation: rise 0.55s ease forwards; }
  .slide.in-view .anim-child:nth-child(1){animation-delay:0.08s}
  .slide.in-view .anim-child:nth-child(2){animation-delay:0.18s}
  .slide.in-view .anim-child:nth-child(3){animation-delay:0.28s}
  .slide.in-view .anim-child:nth-child(4){animation-delay:0.38s}
  .slide.in-view .anim-child:nth-child(5){animation-delay:0.48s}
  .slide.in-view .anim-child:nth-child(6){animation-delay:0.56s}
  @keyframes rise {
    from{opacity:0;transform:translateY(20px)}
    to{opacity:1;transform:translateY(0)}
  }

  /* COUNTDOWN */
  .countdown-grid {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: clamp(8px,2vw,14px); max-width: 460px; width: 100%; margin-top: 0.4rem;
  }
  .cd-unit {
    background: rgba(255,255,255,0.55); border: 1px solid rgba(200,72,120,0.18);
    border-radius: 14px; padding: clamp(0.55rem,2vw,0.9rem) 0.4rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
  }
  .cd-num {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem,6.5vw,3.2rem);
    font-weight: 700; color: #c84878; line-height: 1;
    font-variant-numeric: tabular-nums; min-width: 2ch; text-align: center;
  }
  .cd-label {
    font-size: clamp(8px,1.6vw,10px);
    letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.5; color: #8B2252;
  }

  /* ALBUM COVER */
  .album-slot {
    width: clamp(130px,36vw,210px); height: clamp(130px,36vw,210px);
    border-radius: 14px;
    border: 2px dashed rgba(200,72,120,0.3);
    background: rgba(255,255,255,0.4);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.45rem; font-size: 0.72rem; color: #c84878;
    position: relative; overflow: hidden; cursor: pointer;
    transition: border-color 0.2s;
    flex-shrink: 0;
  }
  .album-slot:hover { border-color: rgba(200,72,120,0.55); }
  .album-slot input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .album-slot img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; border-radius: 12px; }
  .vinyl {
    width: 58px; height: 58px; border-radius: 50%;
    border: 3px solid rgba(200,72,120,0.25);
    display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
  }

  /* PHOTO SLOT */
  .photo-slot {
    width: clamp(150px,42vw,240px); aspect-ratio: 4/5;
    border-radius: 16px; border: 2px dashed rgba(200,72,120,0.3);
    background: rgba(255,255,255,0.4);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.5rem; font-size: 0.78rem; color: #c84878;
    position: relative; overflow: hidden;
  }
  .photo-slot input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .photo-slot img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; border-radius: 14px; }

  /* TRAITS */
  .trait-list { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 0.6rem; max-width: 500px; }
  .trait {
    background: rgba(200,72,120,0.08); border: 1px solid rgba(200,72,120,0.22);
    border-radius: 100px; padding: 0.4rem 1rem;
    font-size: clamp(0.72rem,1.9vw,0.88rem); color: #8B2252;
    transition: all 0.2s;
  }
  .trait:hover { background: rgba(200,72,120,0.16); border-color: rgba(200,72,120,0.45); color: #c84878; }

  /* WISHES */
  .wish-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; margin-top: 0.6rem; max-width: 440px; width: 100%; }
  .wish-list li {
    display: flex; align-items: center; gap: 0.75rem;
    background: rgba(255,255,255,0.5); border-left: 2px solid #c84878;
    border-radius: 0 8px 8px 0; padding: 0.55rem 1rem;
    font-size: clamp(0.82rem,2.1vw,0.97rem); color: #3a1a2a; opacity: 0.9;
  }
  .wish-list li .icon { font-size: 1.05rem; flex-shrink: 0; }

  /* FINAL SLIDE */
  .slide-final .overline { color: #c84878; opacity: 0.7; }
  .slide-final .headline { color: #c84878; }
  .slide-final .headline em { color: #8B2252; }
  .slide-final .subhead { color: #8B2252; }
  .slide-final .body-text { color: #3a1a2a; opacity: 0.7; }

  /* floating PNGs */
  #png-layer { position: absolute; inset: 0; pointer-events: none; z-index: 1; overflow: hidden; }
  .pop-png {
    position: absolute;
    width: clamp(55px,12vw,120px);
    pointer-events: none;
    opacity: 0;
    animation:
      pop-in var(--pop-dur, 0.4s) cubic-bezier(0.34,1.56,0.64,1) var(--pop-delay,0s) forwards,
      float-idle 4s ease-in-out calc(var(--pop-dur,0.4s) + var(--pop-delay,0s)) infinite;
  }
  @keyframes pop-in {
    from { opacity:0; transform: scale(0) rotate(var(--rot,0deg)); }
    to   { opacity:1; transform: scale(1) rotate(var(--rot,0deg)); }
  }
  @keyframes float-idle {
    0%,100% { transform: scale(1) rotate(var(--rot,0deg)) translateY(0); }
    50%     { transform: scale(1) rotate(var(--rot,0deg)) translateY(-10px); }
  }

  /* PNG upload panel */
  #png-upload-panel {
    position: relative; z-index: 3;
    display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 0.5rem;
  }
  .png-btn {
    background: rgba(196,92,46,0.08); border: 1px dashed rgba(196,92,46,0.4);
    border-radius: 10px; padding: 0.38rem 0.9rem;
    font-size: 0.78rem; color: #C45C2E; cursor: pointer;
    position: relative; overflow: hidden; transition: background 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .png-btn:hover { background: rgba(196,92,46,0.18); }
  .png-btn input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }

  /* celebrate button */
  #celebrate-btn {
    background: rgba(196,92,46,0.1); border: 1px solid rgba(196,92,46,0.4);
    color: #C45C2E; border-radius: 100px; padding: 0.55rem 1.8rem;
    font-size: 0.9rem; cursor: pointer; font-family: 'DM Sans',sans-serif;
    letter-spacing: 0.05em; transition: all 0.2s; position: relative; z-index: 3;
  }
  #celebrate-btn:hover { background: rgba(196,92,46,0.2); }

  /* ── PASSWORD GATE (slide 1) ── */
  .gate-small {
    font-size: clamp(0.85rem,2.2vw,1rem);
    color: #a06080; letter-spacing: 0.02em; text-align: center;
    font-family: 'DM Sans', sans-serif;
  }
  .gate-question {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem,5vw,2.6rem);
    font-weight: 700; line-height: 1.2; text-align: center;
    color: #3a1a2a;
  }
  .gate-input-wrap {
    position: relative; width: min(340px,85vw);
  }
  #gate-input {
    width: 100%; padding: 0.85rem 1.2rem;
    border-radius: 16px;
    border: 2px solid rgba(200,100,140,0.3);
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(8px);
    font-family: 'Playfair Display', serif;
    font-size: clamp(1rem,3vw,1.25rem);
    color: #3a1a2a; text-align: center;
    outline: none;
    transition: border-color 0.25s, background 0.25s;
    -webkit-appearance: none;
  }
  #gate-input::placeholder { color: rgba(160,96,128,0.5); }
  #gate-input:focus { border-color: rgba(200,100,140,0.65); background: rgba(255,255,255,0.9); }
  #gate-input.wrong {
    border-color: #e84040;
    background: rgba(255,80,80,0.1);
    animation: gate-shake 0.45s cubic-bezier(0.36,0.07,0.19,0.97);
  }
  @keyframes gate-shake {
    0%,100%{transform:translateX(0)}
    15%{transform:translateX(-9px)}
    30%{transform:translateX(9px)}
    45%{transform:translateX(-7px)}
    60%{transform:translateX(7px)}
    75%{transform:translateX(-4px)}
    90%{transform:translateX(4px)}
  }
  #gate-btn {
    width: min(340px,85vw);
    padding: 0.8rem;
    border-radius: 100px;
    border: none;
    background: linear-gradient(135deg,#e8789a,#c84878);
    color: #fff; font-family: 'DM Sans', sans-serif;
    font-size: 1rem; font-weight: 500;
    cursor: pointer; letter-spacing: 0.04em;
    transition: opacity 0.2s, transform 0.15s;
    box-shadow: 0 4px 20px rgba(200,72,120,0.3);
  }
  #gate-btn:hover { opacity: 0.9; }
  #gate-btn:active { transform: scale(0.97); }
  #gate-success {
    display: none; flex-direction: column;
    align-items: center; gap: 0.6rem; text-align: center;
  }
  #gate-success .emoji { font-size: clamp(4rem,15vw,7rem); animation: pop-emoji 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards; }
  @keyframes pop-emoji { from{opacity:0;transform:scale(0.3)}to{opacity:1;transform:scale(1)} }
  #gate-success .welcome {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.4rem,5vw,2.2rem);
    font-weight: 700; color: #c84878; letter-spacing: 0.04em;
  }
  #gate-success .swipe-hint-gate {
    font-size: 0.82rem; opacity: 0.45; color: #a06080; margin-top: 0.4rem;
    letter-spacing: 0.08em; text-transform: uppercase;
  }

  #confetti-canvas { position: fixed; inset: 0; pointer-events: none; z-index: 1500; }
</style>
</head>
<body>

<canvas id="confetti-canvas"></canvas>

<div id="reel">

  <!-- SLIDE 1: OPENING -->
  <div class="slide slide-1" data-index="0">
    <!-- no deco blobs on white-pink slide -->
    <div class="content-stack">
      <!-- question state -->
      <div id="gate-form" style="display:flex;flex-direction:column;align-items:center;gap:1.1rem;width:100%;">
        <p class="gate-small anim-child">are you really momina??</p>
        <p class="gate-question anim-child">what was the nickname<br>you gave me in our dms?</p>
        <div class="gate-input-wrap anim-child">
          <input id="gate-input" type="text" placeholder="type your answer…" autocomplete="off" autocorrect="off" spellcheck="false" onkeydown="if(event.key==='Enter')checkAnswer()">
        </div>
        <button id="gate-btn" class="anim-child" onclick="checkAnswer()">confirm ✦</button>
      </div>
      <!-- success state -->
      <div id="gate-success">
        <div class="emoji">🤗</div>
        <div class="welcome">welcomeeee</div>
        <p class="swipe-hint-gate">Swipe up to begin ↑</p>
      </div>
    </div>
  </div>

  <!-- SLIDE 2: COUNTDOWN -->
  <div class="slide slide-2" data-index="1">
    <div class="content-stack">
      <p class="overline anim-child">Counting down to the big day</p>
      <div class="headline anim-child" style="font-size:clamp(2rem,7vw,4rem);color:#c84878;">Your Birthday<br><em style="color:#8B2252;">Countdown</em></div>
      <div class="countdown-grid anim-child">
        <div class="cd-unit"><span class="cd-num" id="cd-days">--</span><span class="cd-label">Days</span></div>
        <div class="cd-unit"><span class="cd-num" id="cd-hours">--</span><span class="cd-label">Hours</span></div>
        <div class="cd-unit"><span class="cd-num" id="cd-mins">--</span><span class="cd-label">Mins</span></div>
        <div class="cd-unit"><span class="cd-num" id="cd-secs">--</span><span class="cd-label">Secs</span></div>
